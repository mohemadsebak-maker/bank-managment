/*
    ==========================================================
    STUDENT DATA MANAGEMENT SYSTEM
    ==========================================================
    
    Features:
      1. Add Student
      2. Display All Students
      3. Search Student (by Roll No or Name)
      4. Update Student
      5. Delete Student
      6. Sort Students by Percentage
      7. Show Topper
      8. Exit

    ==========================================================
*/
 
#include <iostream>
#include <fstream>
#include <sstream>
#include <vector>
#include <string>
#include <iomanip>
#include <algorithm>
#include <limits>
 
using namespace std;
 
const string FILENAME = "students.txt";
const int NUM_SUBJECTS = 5;
 

class Student {
private:
    int rollNo;
    string name;
    string department;
    int age;
    double marks[NUM_SUBJECTS];
    double total;
    double percentage;
    char grade;
 
    void calculateResult() {
        total = 0;
        for (int i = 0; i < NUM_SUBJECTS; i++) total += marks[i];
        percentage = total / NUM_SUBJECTS;
 
        if (percentage >= 90) grade = 'A';
        else if (percentage >= 80) grade = 'B';
        else if (percentage >= 70) grade = 'C';
        else if (percentage >= 60) grade = 'D';
        else if (percentage >= 50) grade = 'E';
        else grade = 'F';
    }
 
public:
    Student() : rollNo(0), age(0), total(0), percentage(0), grade(' ') {
        for (int i = 0; i < NUM_SUBJECTS; i++) marks[i] = 0;
    }
 
    // Take input from the user for a new record
    void inputData(int newRoll) {
        rollNo = newRoll;
        cin.ignore();
 
        cout << "Enter Name       : ";
        getline(cin, name);
 
        cout << "Enter Department : ";
        getline(cin, department);
 
        cout << "Enter Age        : ";
        cin >> age;
 
        cout << "Enter marks for " << NUM_SUBJECTS << " subjects (0-100):\n";
        for (int i = 0; i < NUM_SUBJECTS; i++) {
            cout << "  Subject " << i + 1 << ": ";
            cin >> marks[i];
        }
        calculateResult();
    }
 
    // Edit an existing record (press Enter-less flow: just re-enter values)
    void updateData() {
        cin.ignore();
 
        cout << "Enter new Name [" << name << "]: ";
        getline(cin, name);
 
        cout << "Enter new Department [" << department << "]: ";
        getline(cin, department);
 
        cout << "Enter new Age [" << age << "]: ";
        cin >> age;
 
        cout << "Enter new marks:\n";
        for (int i = 0; i < NUM_SUBJECTS; i++) {
            cout << "  Subject " << i + 1 << " [" << marks[i] << "]: ";
            cin >> marks[i];
        }
        calculateResult();
    }
 
    // One-line summary used in the table view
    void display() const {
        cout << left << setw(8) << rollNo
             << setw(20) << name
             << setw(18) << department
             << setw(6) << age
             << setw(10) << fixed << setprecision(2) << percentage
             << setw(6) << grade << "\n";
    }
 
    // Full detail view used for search results
    void displayDetailed() const {
        cout << "\n--------- Student Details ---------\n";
        cout << "Roll No     : " << rollNo << "\n";
        cout << "Name        : " << name << "\n";
        cout << "Department  : " << department << "\n";
        cout << "Age         : " << age << "\n";
        cout << "Marks       : ";
        for (int i = 0; i < NUM_SUBJECTS; i++) cout << marks[i] << " ";
        cout << "\n";
        cout << "Total       : " << total << "\n";
        cout << "Percentage  : " << fixed << setprecision(2) << percentage << "%\n";
        cout << "Grade       : " << grade << "\n";
        cout << "------------------------------------\n";
    }
 
    int getRollNo() const { return rollNo; }
    string getName() const { return name; }
    double getPercentage() const { return percentage; }
 
    // Convert record to a single '|'-delimited line for file storage
    string serialize() const {
        ostringstream oss;
        oss << rollNo << "|" << name << "|" << department << "|" << age;
        for (int i = 0; i < NUM_SUBJECTS; i++) oss << "|" << marks[i];
        return oss.str();
    }
 
    // Rebuild a record from a stored line
    static Student deserialize(const string& line) {
        Student s;
        stringstream ss(line);
        string token;
 
        getline(ss, token, '|'); s.rollNo = stoi(token);
        getline(ss, token, '|'); s.name = token;
        getline(ss, token, '|'); s.department = token;
        getline(ss, token, '|'); s.age = stoi(token);
        for (int i = 0; i < NUM_SUBJECTS; i++) {
            getline(ss, token, '|');
            s.marks[i] = stod(token);
        }
        s.calculateResult();
        return s;
    }
};
 
// ----------------------------------------------------------
// StudentManagementSystem: owns the list of students and
// handles all file I/O + menu operations
// ----------------------------------------------------------
class StudentManagementSystem {
private:
    vector<Student> students;
    int nextRollNo;
 
    void loadFromFile() {
        ifstream file(FILENAME);
        if (!file) return;
 
        string line;
        while (getline(file, line)) {
            if (line.empty()) continue;
            students.push_back(Student::deserialize(line));
        }
        file.close();
 
        for (auto &s : students)
            if (s.getRollNo() >= nextRollNo) nextRollNo = s.getRollNo() + 1;
    }
 
    void saveToFile() {
        ofstream file(FILENAME);
        for (auto &s : students) file << s.serialize() << "\n";
        file.close();
    }
 
    int findIndexByRoll(int roll) {
        for (size_t i = 0; i < students.size(); i++)
            if (students[i].getRollNo() == roll) return static_cast<int>(i);
        return -1;
    }
 
public:
    StudentManagementSystem() : nextRollNo(1) {
        loadFromFile();
    }
 
    void addStudent() {
        Student s;
        s.inputData(nextRollNo);
        students.push_back(s);
        nextRollNo++;
        saveToFile();
        cout << "\n[OK] Student added successfully with Roll No: " << s.getRollNo() << "\n";
    }
 
    void displayAll() const {
        if (students.empty()) {
            cout << "\nNo student records found.\n";
            return;
        }
        cout << "\n" << left << setw(8) << "Roll" << setw(20) << "Name"
             << setw(18) << "Department" << setw(6) << "Age"
             << setw(10) << "Percent" << setw(6) << "Grade" << "\n";
        cout << string(68, '-') << "\n";
        for (auto &s : students) s.display();
    }
 
    void searchStudent() {
        cout << "Search by: 1. Roll No   2. Name\n> ";
        int choice;
        cin >> choice;
 
        if (choice == 1) {
            int roll;
            cout << "Enter Roll No: ";
            cin >> roll;
            int idx = findIndexByRoll(roll);
            if (idx != -1) students[idx].displayDetailed();
            else cout << "Student not found.\n";
        } else if (choice == 2) {
            string name;
            cin.ignore();
            cout << "Enter Name: ";
            getline(cin, name);
            bool found = false;
            for (auto &s : students) {
                if (s.getName() == name) {
                    s.displayDetailed();
                    found = true;
                }
            }
            if (!found) cout << "Student not found.\n";
        } else {
            cout << "Invalid choice.\n";
        }
    }
 
    void updateStudent() {
        int roll;
        cout << "Enter Roll No to update: ";
        cin >> roll;
        int idx = findIndexByRoll(roll);
        if (idx == -1) {
            cout << "Student not found.\n";
            return;
        }
        students[idx].updateData();
        saveToFile();
        cout << "[OK] Student record updated.\n";
    }
 
    void deleteStudent() {
        int roll;
        cout << "Enter Roll No to delete: ";
        cin >> roll;
        int idx = findIndexByRoll(roll);
        if (idx == -1) {
            cout << "Student not found.\n";
            return;
        }
        cout << "Are you sure you want to delete " << students[idx].getName() << "? (y/n): ";
        char c;
        cin >> c;
        if (c == 'y' || c == 'Y') {
            students.erase(students.begin() + idx);
            saveToFile();
            cout << "[OK] Student deleted.\n";
        } else {
            cout << "Deletion cancelled.\n";
        }
    }
 
    void sortByPercentage() {
        if (students.empty()) {
            cout << "No records to sort.\n";
            return;
        }
        sort(students.begin(), students.end(), [](const Student& a, const Student& b) {
            return a.getPercentage() > b.getPercentage();
        });
        saveToFile();
        cout << "[OK] Students sorted by percentage (highest first).\n";
        displayAll();
    }
 
    void showTopper() const {
        if (students.empty()) {
            cout << "No records found.\n";
            return;
        }
        auto topper = max_element(students.begin(), students.end(),
            [](const Student& a, const Student& b) {
                return a.getPercentage() < b.getPercentage();
            });
        cout << "\n*** Top Performer ***";
        topper->displayDetailed();
    }
};
 
// ----------------------------------------------------------
// Small helper to keep cin robust against invalid input
// ----------------------------------------------------------
int readMenuChoice() {
    int choice;
    while (!(cin >> choice)) {
        cout << "Invalid input. Please enter a number: ";
        cin.clear();
        cin.ignore(numeric_limits<streamsize>::max(), '\n');
    }
    return choice;
}
 
int main() {
    StudentManagementSystem sms;
    int choice;
 
    do {
        cout << "\n========= Student Data Management System =========\n";
        cout << "1. Add Student\n";
        cout << "2. Display All Students\n";
        cout << "3. Search Student\n";
        cout << "4. Update Student\n";
        cout << "5. Delete Student\n";
        cout << "6. Sort Students by Percentage\n";
        cout << "7. Show Topper\n";
        cout << "8. Exit\n";
        cout << "====================================================\n";
        cout << "Enter your choice: ";
 
        choice = readMenuChoice();
 
        switch (choice) {
            case 1: sms.addStudent();      break;
            case 2: sms.displayAll();      break;
            case 3: sms.searchStudent();   break;
            case 4: sms.updateStudent();   break;
            case 5: sms.deleteStudent();   break;
            case 6: sms.sortByPercentage();break;
            case 7: sms.showTopper();      break;
            case 8: cout << "Exiting... Data saved. Goodbye!\n"; break;
            default: cout << "Invalid choice, please try again.\n";
        }
    } while (choice != 8);
 
    return 0;
}
